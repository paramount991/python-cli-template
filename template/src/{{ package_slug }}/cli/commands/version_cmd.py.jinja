"""version: 版本信息子命令."""

import typer

from {{ package_slug }}.core import version as ver

app = typer.Typer(invoke_without_command=True)  # 无子命令时直接调用回调, 打印版本


@app.callback()
def version() -> None:
    """显示版本信息."""
    typer.echo(f'{ver.PROJECT_DESC} V{ver.PROJECT_VERSION}')
