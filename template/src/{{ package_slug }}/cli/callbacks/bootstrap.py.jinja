"""应用启动: 加载配置并初始化日志."""

from pathlib import Path

from platformdirs import user_log_dir

from {{ package_slug }}.core import constants as const
from {{ package_slug }}.core.config.settings import Settings, load_settings
from {{ package_slug }}.core.log import init_logging


def bootstrap_app(
    config_file: str | None = None,
    msg_level: const.LogLevel = const.LogLevel.INFO,
    log_file: str | None = None,
) -> Settings:
    """加载配置, 注入 CLI 覆盖, 初始化日志.

    优先级: CLI 参数 > 环境变量 > TOML 文件 > 默认值.
    """
    cfg = load_settings(config_file)

    # CLI 参数作为最高优先级覆盖
    cfg.log.level = msg_level

    # 日志文件路径: 默认写入 user_log_dir, 避免 CWD 漂移
    log_file_path: str | None = log_file
    if not log_file_path and cfg.log.dir_name and cfg.log.file_name:
        log_file_path = str(
            Path(user_log_dir(const.PACKAGE_NAME, appauthor=False))
            / cfg.log.dir_name
            / cfg.log.file_name
        )

    log_config = cfg.log.model_dump()
    log_config['file_path'] = log_file_path
    init_logging(log_config)

    return cfg
