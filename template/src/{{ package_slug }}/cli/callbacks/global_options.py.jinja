"""CLI 全局选项 — 现代化实现: -v/-q 计数模式."""

import typer
from pydantic import BaseModel, ConfigDict

from {{ package_slug }}.core import constants as const

from .bootstrap import bootstrap_app


class GlobalOptions(BaseModel):
    """命令行全局选项快照, 存入 ctx.obj 供子命令读取."""

    model_config = ConfigDict(frozen=True, extra='forbid')

    config_file: str | None
    log_file: str | None
    msg_level: const.LogLevel


def _version_callback(value: bool) -> None:
    """--version / -V 回调 (eager, 优先级最高)."""
    if value:
        typer.echo(f'{const.PROJECT_DESC} V{const.PROJECT_VERSION}')
        raise typer.Exit()


def _resolve_log_level(verbose: int, quiet: int) -> const.LogLevel:
    """根据 -v/-q 计数解析日志级别.

    -q / --quiet 可叠加:
      -q       → WARNING (隐藏 INFO/DEBUG)
      -q -q    → ERROR   (仅显示错误)

    -v / --verbose 可叠加:
      -v       → DEBUG   (显示所有)
    """
    if quiet >= 2:
        return const.LogLevel.ERROR
    if quiet >= 1:
        return const.LogLevel.WARNING
    if verbose >= 1:
        return const.LogLevel.DEBUG
    return const.LogLevel.INFO


def global_options(
    ctx: typer.Context,
    config_file: str | None = typer.Option(
        None,
        '--config',
        help=f'指定配置文件 (默认: {const.DEFAULT_CONFIG_PATH})',
        show_default=False,
        rich_help_panel='全局选项',
    ),
    log_file: str | None = typer.Option(
        None,
        '--logfile',
        metavar='FILE',
        help='日志文件',
        rich_help_panel='全局选项',
    ),
    verbose: int = typer.Option(
        0,
        '--verbose',
        '-v',
        count=True,
        help='详细输出 (-v for DEBUG)',
        rich_help_panel='全局选项',
    ),
    quiet: int = typer.Option(
        0,
        '--quiet',
        '-q',
        count=True,
        help='安静模式 (-q for WARN, -qq for ERROR)',
        rich_help_panel='全局选项',
    ),
    version: bool = typer.Option(
        None,
        '--version',
        '-V',
        callback=_version_callback,
        is_eager=True,
        help='显示版本信息',
        rich_help_panel='全局选项',
    ),
) -> None:
    """全局选项回调: 解析参数, 存入上下文, 按需启动应用."""
    msg_level = _resolve_log_level(verbose, quiet)

    # 解析配置路径: 仅当文件存在或用户显式指定时才加载
    resolved_config: str | None = config_file
    if config_file is None:
        default_path = const.DEFAULT_CONFIG_PATH
        if default_path.exists():
            resolved_config = str(default_path)

    ctx.obj = GlobalOptions(
        config_file=resolved_config,
        log_file=log_file,
        msg_level=msg_level,
    )

    sub_command = ctx.invoked_subcommand
    if sub_command is None:
        typer.echo('请使用子命令 help 查看帮助')
        raise typer.Exit()

    bootstrap_app(
        config_file=resolved_config,
        msg_level=msg_level,
        log_file=log_file,
    )
