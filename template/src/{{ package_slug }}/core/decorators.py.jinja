"""核心装饰器模块."""

from collections.abc import Callable
from functools import wraps
from typing import Any, ParamSpec, TypeVar

import typer
from pydantic import ValidationError

from .log import get_logger

P = ParamSpec('P')
T = TypeVar('T')


def _format_validation_error(e: ValidationError) -> str:
    """将 Pydantic ValidationError 格式化为用户可读的列表."""
    lines: list[str] = []
    for error in e.errors():
        loc = '.'.join(str(p) for p in error['loc'])
        msg = error['msg']
        lines.append(f'  {loc}: {msg}')
    return '\n'.join(lines)


def log_command(cmd_name: str) -> Callable[[Callable[P, T]], Callable[P, T]]:
    """命令执行日志装饰器 (DEBUG 级别, 避免终端噪音)."""
    log = get_logger()

    def decorator(func: Callable[P, T]) -> Callable[P, T]:
        @wraps(func)
        def wrapper(*args: P.args, **kwargs: P.kwargs) -> T:
            params = []
            if args:
                params.extend(
                    str(a) for a in args
                    if not isinstance(a, typer.Context)
                )
            if kwargs:
                params.extend(
                    f'{k}={v}' for k, v in kwargs.items()
                    if k != 'ctx'
                )
            params_str = ', '.join(params) if params else '(无)'
            log.debug(f'执行命令: {cmd_name} | {params_str}')
            return func(*args, **kwargs)

        return wrapper

    return decorator


def handle_errors[**P, T](func: Callable[P, T]) -> Callable[P, T]:
    """统一错误处理装饰器 — 异常转为用户友好的退出信息."""
    log = get_logger()

    @wraps(func)
    def wrapper(*args: P.args, **kwargs: P.kwargs) -> T:
        try:
            return func(*args, **kwargs)
        except typer.Exit:
            raise
        except ValidationError as e:
            typer.secho('配置校验失败:', fg=typer.colors.RED, err=True)
            typer.secho(_format_validation_error(e), fg=typer.colors.RED, err=True)
            log.error('配置校验失败', exc_info=True)
            raise typer.Exit(code=1) from None
        except Exception as e:
            log.error(f'命令执行失败: {e}', exc_info=True)
            typer.secho(f'错误: {e}', fg=typer.colors.RED, err=True)
            raise typer.Exit(code=1) from None

    return wrapper
