            tomli_w.dump(minimal_config_data, f)
        result = runner.invoke(
            app, ['--config', str(config_path), 'config', 'set', 'env.debug', 'true']
        )
        assert result.exit_code == 0
        assert '无效的布尔值' not in result.stdout

    def test_valid_bool_false_no_warning(self, tmp_path: Path, minimal_config_data: dict) -> None:
        config_path = tmp_path / 'config.toml'
        with open(config_path, 'wb') as f:
