        assert result.exit_code == 0

    def test_quiet_flag_accepted(self) -> None:
        result = runner.invoke(app, ['-q', 'version'])
        assert result.exit_code == 0

    def test_double_quiet_accepted(self) -> None:
        result = runner.invoke(app, ['-qq', 'version'])
        assert result.exit_code == 0


class TestMainWithoutSubcommand:
    """测试不带子命令时的行为."""

    def test_no_subcommand_shows_usage(self) -> None:
        result = runner.invoke(app, [])
        # 无子命令时应提供帮助信息并退出
        assert result.exit_code != 0 or '使用子命令' in result.stdout or 'help' in result.stdout

    def test_help_flag_shows_usage(self) -> None:
        result = runner.invoke(app, ['--help'])
        assert result.exit_code == 0

