class TestConfigSensitiveMasking:
    """测试 config get/list 敏感字段脱敏."""

    def test_get_masks_password(self, tmp_path: Path, minimal_config_data: dict) -> None:
        config_path = tmp_path / 'config.toml'
        data = {**minimal_config_data, 'db': {**minimal_config_data['db'], 'password': 'secret123'}}
        with open(config_path, 'wb') as f:
            tomli_w.dump(data, f)
        result = runner.invoke(
            app, ['--config', str(config_path), 'config', 'get', 'db.password']
        )
        assert result.exit_code == 0
        assert '********' in result.stdout
        assert 'secret123' not in result.stdout

    def test_list_masks_password(self, tmp_path: Path, minimal_config_data: dict) -> None:
        config_path = tmp_path / 'config.toml'
        data = {**minimal_config_data, 'db': {**minimal_config_data['db'], 'password': 'secret123'}}
        with open(config_path, 'wb') as f:
            tomli_w.dump(data, f)
        result = runner.invoke(app, ['--config', str(config_path), 'config', 'list'])
        assert result.exit_code == 0
        assert '********' in result.stdout
        assert 'secret123' not in result.stdout

