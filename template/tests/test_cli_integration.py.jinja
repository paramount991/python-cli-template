class TestVersionFlag:
    """测试 --version / -V 全局选项."""

    def test_version_flag_long(self) -> None:
        result = runner.invoke(app, ['--version'])
        assert result.exit_code == 0
        assert 'V' in result.stdout

    def test_version_flag_short(self) -> None:
        result = runner.invoke(app, ['-V'])
        assert result.exit_code == 0
        assert 'V' in result.stdout

    def test_version_flag_with_subcommand_also_works(self) -> None:
        """--version 是 eager option, 即使有子命令也应优先执行."""
        result = runner.invoke(app, ['--version', 'config'])
        assert result.exit_code == 0
        assert 'V' in result.stdout


class TestGlobalOptionsVerboseQuiet:
    """测试 -v / -q 全局选项."""

    def test_verbose_flag_accepted(self) -> None:
