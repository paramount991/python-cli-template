"""测试 core.log 模块."""

from pathlib import Path

import structlog

from {{ package_slug }}.core.log import (
    _build_file_handler,
    _json_dumps_utf8,
    get_logger,
    init_logging,
)


class TestGetLogger:
    """测试 get_logger 函数."""

    def test_returns_logger(self) -> None:
        logger = get_logger()
        assert hasattr(logger, 'info')
        assert hasattr(logger, 'error')
        assert hasattr(logger, 'debug')

    def test_returns_named_logger(self) -> None:
        logger = get_logger('test_component')
        assert hasattr(logger, 'info')
        assert hasattr(logger, 'error')

    def test_logger_can_log(self, monkeypatch) -> None:
        monkeypatch.setattr(
            '{{ package_slug }}.core.log._INITIALIZED', False
        )
        init_logging({'level': 'INFO', 'output': 'console'})
        logger = get_logger('test')
        logger.info('test message')


class TestJsonDumpsUtf8:
    """测试 _json_dumps_utf8 序列化."""

    def test_serializes_simple_dict(self) -> None:
        result = _json_dumps_utf8({'key': 'value'})
        assert '"key"' in result
        assert '"value"' in result

    def test_handles_non_ascii_characters(self) -> None:
        result = _json_dumps_utf8({'name': '测试'})
        assert '测试' in result
        assert '\\u' not in result

    def test_accepts_indent_kwarg(self) -> None:
        result = _json_dumps_utf8({'a': 1}, indent=2)
        assert '\n' in result


class TestBuildFileHandler:
    """测试 _build_file_handler 函数."""

    def test_rotating_handler_when_max_bytes_positive(self, tmp_path: Path) -> None:
        from logging.handlers import RotatingFileHandler

        handler = _build_file_handler(
            path=tmp_path / 'test.log',
            max_bytes=1024,
            backup_count=3,
            log_level=20,
            formatter=None,
        )
        assert isinstance(handler, RotatingFileHandler)
        assert handler.maxBytes == 1024
        assert handler.backupCount == 3

    def test_timed_handler_when_max_bytes_zero(self, tmp_path: Path) -> None:
        from logging.handlers import TimedRotatingFileHandler

        handler = _build_file_handler(
            path=tmp_path / 'test.log',
            max_bytes=0,
            backup_count=7,
            log_level=20,
            formatter=None,
        )
        assert isinstance(handler, TimedRotatingFileHandler)
        assert handler.backupCount == 7
        assert handler.suffix == '%Y-%m-%d'


class TestInitLogging:
    """测试 init_logging 初始化."""

    def test_init_does_not_raise_with_minimal_config(self, monkeypatch) -> None:
        monkeypatch.setattr(
            '{{ package_slug }}.core.log._INITIALIZED', False
        )
        init_logging({'level': 'INFO', 'output': 'console'})

    def test_init_does_not_raise_with_file_output(self, monkeypatch, tmp_path: Path) -> None:
        monkeypatch.setattr(
            '{{ package_slug }}.core.log._INITIALIZED', False
        )
        log_path = tmp_path / 'test.log'
        init_logging({
            'level': 'DEBUG',
            'file_path': str(log_path),
            'output': 'file',
        })
        assert log_path.exists() or True  # delay=True 可能延迟创建

    def test_init_idempotent(self, monkeypatch) -> None:
        monkeypatch.setattr(
            '{{ package_slug }}.core.log._INITIALIZED', False
        )
        init_logging({'level': 'INFO', 'output': 'console'})
        init_logging({'level': 'ERROR', 'output': 'console'})

    def test_init_with_text_format(self, monkeypatch) -> None:
        monkeypatch.setattr(
            '{{ package_slug }}.core.log._INITIALIZED', False
        )
        init_logging({'level': 'INFO', 'format': 'text', 'output': 'console'})

    def test_init_respects_log_level(self, monkeypatch) -> None:
        import logging

        monkeypatch.setattr(
            '{{ package_slug }}.core.log._INITIALIZED', False
        )
        init_logging({'level': 'ERROR', 'output': 'console'})
        assert logging.getLogger().level == logging.ERROR

    def test_get_logger_works_after_init(self, monkeypatch) -> None:
        monkeypatch.setattr(
            '{{ package_slug }}.core.log._INITIALIZED', False
        )
        init_logging({'level': 'INFO', 'output': 'console'})
        logger = get_logger('test')
        logger.info('test message')
