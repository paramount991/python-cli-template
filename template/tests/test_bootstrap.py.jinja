"""测试 cli.callbacks.bootstrap 模块."""

from pathlib import Path

import tomli_w

from {{ package_slug }}.cli.callbacks.bootstrap import (
    bootstrap_app,
    resolve_config,
    resolve_log_path,
)
from {{ package_slug }}.core.config.loader import clear_settings
from {{ package_slug }}.core.config.settings import Settings
from {{ package_slug }}.core.constants import LogLevel


class TestResolveConfig:
    """测试 resolve_config 函数."""

    def test_returns_settings_when_file_not_found(self) -> None:
        clear_settings()
        cfg = resolve_config('/nonexistent/path.toml')
        assert isinstance(cfg, Settings)

    def test_loads_existing_config_file(self, tmp_path: Path, minimal_config_data: dict) -> None:
        clear_settings()
        config_path = tmp_path / 'config.toml'
        data = {**minimal_config_data, 'app': {**minimal_config_data['app'], 'name': 'resolved-app'}}
        with open(config_path, 'wb') as f:
            tomli_w.dump(data, f)
        cfg = resolve_config(str(config_path))
        assert cfg.app.name == 'resolved-app'

    def test_none_returns_default_settings(self) -> None:
        clear_settings()
        cfg = resolve_config(None)
        assert isinstance(cfg, Settings)


class TestResolveLogPath:
    """测试 resolve_log_path 函数."""

    def test_returns_explicit_log_file(self) -> None:
        result = resolve_log_path('/custom/path.log', 'logs', 'app.log')
        assert result == '/custom/path.log'

    def test_returns_user_log_dir_when_no_explicit(self) -> None:
        result = resolve_log_path(None, 'logs', 'app.log')
        assert result is not None
        assert result.endswith('app.log')

    def test_returns_none_when_dir_name_empty(self) -> None:
        result = resolve_log_path(None, '', 'app.log')
        assert result is None

    def test_returns_none_when_file_name_empty(self) -> None:
        result = resolve_log_path(None, 'logs', '')
        assert result is None


class TestBootstrapApp:
    """测试 bootstrap_app 编排函数."""

    def test_returns_settings_with_defaults(self) -> None:
        clear_settings()
        cfg = bootstrap_app()
        assert isinstance(cfg, Settings)
        assert cfg.app is not None
        assert cfg.env is not None

    def test_loads_from_config_file(self, tmp_path: Path, minimal_config_data: dict) -> None:
        clear_settings()
        config_path = tmp_path / 'config.toml'
        data = {**minimal_config_data, 'app': {**minimal_config_data['app'], 'name': 'loaded-app'}}
        with open(config_path, 'wb') as f:
            tomli_w.dump(data, f)
        cfg = bootstrap_app(config_file=str(config_path))
        assert cfg.app.name == 'loaded-app'

    def test_cli_msg_level_overrides(self) -> None:
        clear_settings()
        cfg = bootstrap_app(msg_level=LogLevel.ERROR)
        assert cfg.log.level == LogLevel.ERROR

    def test_cli_log_file_overrides(self, tmp_path: Path) -> None:
        clear_settings()
        log_file = tmp_path / 'custom.log'
        bootstrap_app(log_file=str(log_file))
        import logging
        root_handlers = logging.getLogger().handlers
        assert len(root_handlers) > 0

    def test_nonexistent_config_falls_back_to_defaults(self) -> None:
        clear_settings()
        cfg = bootstrap_app(config_file='/nonexistent/path.toml')
        assert isinstance(cfg, Settings)
