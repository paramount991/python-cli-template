"""测试 cli.callbacks.bootstrap 模块."""

from pathlib import Path
from unittest.mock import patch

import tomli_w

from {{ package_slug }}.cli.callbacks.bootstrap import bootstrap_app
from {{ package_slug }}.core.config.settings import Settings, clear_settings
from {{ package_slug }}.core.constants import LogLevel


class TestBootstrapApp:
    """测试 bootstrap_app 函数."""

    @patch('{{ package_slug }}.cli.callbacks.bootstrap.init_logging')
    def test_returns_settings_with_defaults(self, mock_init) -> None:
        clear_settings()
        cfg = bootstrap_app()
        assert isinstance(cfg, Settings)
        assert cfg.app is not None
        assert cfg.env is not None

    @patch('{{ package_slug }}.cli.callbacks.bootstrap.init_logging')
    def test_loads_from_config_file(self, mock_init, tmp_path: Path) -> None:
        clear_settings()
        config_path = tmp_path / 'config.toml'
        data = {
            'app': {'name': 'loaded-app'},
            'env': {'environment': 'development', 'debug': False},
            'log': {'level': 'INFO', 'format': 'json', 'output': 'console',
                    'dir_name': 'logs', 'file_name': 'app.log',
                    'max_bytes': 10485760, 'backup_count': 5},
            'db': {'type': 'sqlite', 'host': 'localhost', 'port': 5432,
                   'username': 'test', 'password': '', 'database': 'test',
                   'pool_size': 20, 'max_overflow': 10,
                   'pool_timeout': 30, 'pool_recycle': 3600},
        }
        with open(config_path, 'wb') as f:
            tomli_w.dump(data, f)
        cfg = bootstrap_app(config_file=str(config_path))
        assert cfg.app.name == 'loaded-app'

    @patch('{{ package_slug }}.cli.callbacks.bootstrap.init_logging')
    def test_cli_msg_level_overrides(self, mock_init) -> None:
        clear_settings()
        cfg = bootstrap_app(msg_level=LogLevel.ERROR)
        assert cfg.log.level == LogLevel.ERROR

    @patch('{{ package_slug }}.cli.callbacks.bootstrap.init_logging')
    def test_cli_log_file_overrides(self, mock_init) -> None:
        clear_settings()
        bootstrap_app(log_file='/custom/path.log')
        log_config = mock_init.call_args[0][0]
        assert log_config['file_path'] == '/custom/path.log'

    @patch('{{ package_slug }}.cli.callbacks.bootstrap.init_logging')
    def test_nonexistent_config_falls_back_to_defaults(self, mock_init) -> None:
        clear_settings()
        cfg = bootstrap_app(config_file='/nonexistent/path.toml')
        assert isinstance(cfg, Settings)
