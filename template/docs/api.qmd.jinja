## {{ package_slug }}.core.config — 配置管理

### Settings

```python
class Settings(BaseSettings):
    app: AppConfig               # 应用配置
    env: EnvironmentConfig       # 环境配置
    log: LogConfig               # 日志配置
    db: DatabaseConfig           # 数据库配置
    extra_config: dict[str, Any] # 额外配置

    def get_database_url(self) -> str
    def dict_without_sensitive(self) -> dict[str, Any]

    @classmethod
    def from_toml(cls, toml_path: str | Path) -> Settings
        """从 TOML 文件加载, 环境变量自动覆盖同名配置"""

# 单例访问
def get_settings(file_path: str | Path | None = None) -> Settings
def load_settings(file_path: str | Path | None = None,
                  override_path: str | Path | None = None) -> Settings
def clear_settings() -> None

# 序列化
def save_default_config(file_path: str | Path, ...) -> Path
def save_config_file(data: dict[str, Any], file_path: str | Path) -> None
```

### AppConfig

```python
class AppConfig(BaseConfig):
    name: str         # 默认 "{{ project_slug }}"
    version: str      # 默认 动态版本
    description: str  # 默认 "{{ project_description }}"
```

### EnvironmentConfig

```python
class EnvironmentConfig(BaseConfig):
    environment: EnvironmentType  # 默认 DEVELOPMENT
    debug: bool                   # 默认 False

    def is_development(self) -> bool
    def is_production(self) -> bool
    def is_testing(self) -> bool
    def is_staging(self) -> bool
```

### DatabaseConfig

```python
class DatabaseConfig(BaseConfig):
    type: DatabaseType  # 默认 POSTGRESQL
    host: str           # 默认 "localhost"
    port: int           # 默认 5432
    username: str       # 默认 "postgres"
    password: str       # 默认 ""
    database: str       # 默认 "app"
    pool_size: int      # 默认 20
    max_overflow: int   # 默认 10
    pool_timeout: int   # 默认 30
    pool_recycle: int   # 默认 3600

    @property
    def url(self) -> str  # 数据库连接 URL
```

### LogConfig

```python
class LogConfig(BaseConfig):
    level: LogLevel       # 默认 INFO
    format: str           # 默认 "json"
    output: str           # 默认 "console"
    dir_name: str         # 默认 "logs"
    file_name: str        # 默认 "app.log"
    max_bytes: int        # 默认 10485760 (10MB)
    backup_count: int     # 默认 5
```

